# Yandex Tracker
TRACKER_OAUTH_TOKEN=your-tracker-oauth-token
TRACKER_ORG_ID=8426512
TRACKER_API_BASE=https://api.tracker.yandex.net
# "360" = Yandex 360 org (header X-Org-ID), "cloud" = Yandex Cloud org (X-Cloud-Org-ID)
TRACKER_ORG_TYPE=360

# Portfolio IDs (hardcoded mapping for MVP)
PORTFOLIO_DOMAIN_ID=69e213652577131acba63864
PORTFOLIO_SUBDOMAIN_ID=69e21375562b1c65ac0cdb8b
PORTFOLIO_TEAM_ID=69e2138070fcad39d9d16d5f

# Pachca
PACHCA_ACCESS_TOKEN=your-pachca-token
PACHCA_API_BASE=https://api.pachca.com/api/shared/v1
PACHCA_TARGET_CHAT_ID=37998444

# Webhook auth (shared secret between Pachca and the bot)
WEBHOOK_API_KEY=change-me

# Runtime
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO

# Business rules
STATUS_FRESHNESS_DAYS=6
WEEKLY_STATUS_TAG=#WeeklyStatus
